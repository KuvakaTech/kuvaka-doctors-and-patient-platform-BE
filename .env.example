# Copy to .env and fill in for local development.
# DJANGO_READ_DOT_ENV_FILE must be true for manage.py to load this file.
DJANGO_READ_DOT_ENV_FILE=true
DJANGO_SETTINGS_MODULE=config.settings.local

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=["*"]
DJANGO_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]

DATABASE_URL=postgres://postgres:postgres@localhost:5432/kuvaka
REDIS_URL=redis://localhost:6379/0

# Transactional email (Brevo) — used for doctor email verification/password
# reset and patient login-OTP emails. Leave BREVO_API_KEY blank to log emails
# to the console instead of sending them (fine for local dev).
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@kuvaka.io
BREVO_SENDER_NAME=Kuvaka

OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Account lockout (HIPAA § 164.308(a)(5)(ii)(D))
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINS=30

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_HISTORY_COUNT=5

# MFA / TOTP
MFA_TOKEN_EXPIRY_SECONDS=180
MFA_ISSUER_NAME=Kuvaka
